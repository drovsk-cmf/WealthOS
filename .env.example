# ============================================
# Oniefy (WealthOS) - Environment Variables
# ============================================
# Copie este arquivo para .env.local e preencha os valores
# NUNCA commite o .env.local no repositorio

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ATENCAO: a service_role key NUNCA deve ser exposta no frontend.
# Usada apenas em API routes do Next.js (server-side).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Supabase Project ID (para geracao de tipos) ---
SUPABASE_PROJECT_ID=your-project-id

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Web Push (VAPID) ---
# Gerar com: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=mailto:admin@oniefy.com

# --- Cron Secrets ---
# Protegem endpoints /api/push/send e /api/digest/send contra acesso nao autorizado.
# Gerar com: openssl rand -hex 32
CRON_SECRET=your-cron-secret
DIGEST_CRON_SECRET=your-digest-cron-secret

# --- Email (Resend) ---
# Usado para envio do weekly digest. Sem configurar, o endpoint retorna preview sem enviar.
RESEND_API_KEY=your-resend-api-key

# --- Apple Push Notifications (APNs) ---
# Usado apenas nas Edge Functions (servidor)
APNS_KEY_ID=your-apple-key-id
APNS_TEAM_ID=your-apple-team-id
APNS_BUNDLE_ID=com.oniefy.app
# Conteudo da chave .p8 (base64 encoded)
APNS_PRIVATE_KEY=your-base64-encoded-p8-key

# --- Redis (Future) ---
# Future: migrate in-memory rate limiter to Redis for serverless compatibility
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
